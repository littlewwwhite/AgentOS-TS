{
  "name": "agentos-ts",
  "version": "0.1.0",
  "type": "module",
  "description": "Video production pipeline agent built on Claude Agent SDK (TypeScript)",
  "bin": {
    "agentos": "dist/index.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "server": "bun src/server.ts",
    "sandbox": "bun src/sandbox.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "format": "biome format --write src/ tests/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "e2b": "^2.14.1",
    "hono": "^4.12.5",
    "minimatch": "^10.0.1",
    "ora": "^8.2.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
