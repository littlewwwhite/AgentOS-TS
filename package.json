{
  "name": "agentos-ts",
  "version": "0.1.0",
  "type": "module",
  "description": "Video production pipeline agent built on Claude Agent SDK (TypeScript)",
  "scripts": {
    "start": "bun src/local-entry.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "format": "biome format --write src/ tests/",
    "server": "bun src/server.ts",
    "dev": "bun src/server.ts & cd web && bun dev",
    "dev:web": "cd web && bun dev"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
