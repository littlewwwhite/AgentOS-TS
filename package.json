{
  "name": "agentos-ts",
  "version": "0.1.0",
  "type": "module",
  "description": "Video production pipeline agent built on Claude Agent SDK (TypeScript)",
  "bin": {
    "agentos": "dist/index.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "sandbox": "bun src/sandbox.ts",
    "start:e2b": "bun scripts/e2b-repl.ts",
    "build": "tsc",
    "build:e2b": "bun run build && bun e2b/build.ts",
    "test": "vitest run",
    "test:e2b": "vitest run --config vitest.e2b.config.ts",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "format": "biome format --write src/ tests/",
    "server": "bun src/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "e2b": "^2.14.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
