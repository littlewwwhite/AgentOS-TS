# Music Matcher 默认配置

# Gemini 模型参数
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_TEMPERATURE=1.0
GEMINI_THINKING_LEVEL=low
GEMINI_MEDIA_RESOLUTION=medium
# ChatFire Gemini proxy
GEMINI_BASE_URL=https://api.chatfire.cn/gemini
# GEMINI_API_KEY - set this to the ChatFire key value
GEMINI_API_KEY=

# 上传前压缩（Gemini 只取 1fps，高码率原片浪费带宽）
COMPRESS_BEFORE_UPLOAD=true
COMPRESS_RESOLUTION=720
COMPRESS_FPS=12
COMPRESS_CRF=28
COMPRESS_SKIP_UNDER_MB=100

# 合成参数
COMPOSE_MUSIC_VOLUME_DB=-6
COMPOSE_FADE_IN=0.5
COMPOSE_FADE_OUT=1.0
COMPOSE_MUSIC_REF_LUFS=-14
COMPOSE_DUCKING=false
