# Music Matcher 默认配置

# aos-cli video.analyze 参数
VIDEO_ANALYZE_MODEL=gemini-3.1-pro-preview
VIDEO_ANALYZE_TEMPERATURE=1.0
VIDEO_ANALYZE_THINKING_LEVEL=low
VIDEO_ANALYZE_MEDIA_RESOLUTION=medium

# 上传前压缩（降低多模态分析输入成本）
COMPRESS_BEFORE_UPLOAD=true
COMPRESS_RESOLUTION=720
COMPRESS_FPS=12
COMPRESS_CRF=28
COMPRESS_SKIP_UNDER_MB=100

# 合成参数
COMPOSE_MUSIC_VOLUME_DB=-6
COMPOSE_FADE_IN=0.5
COMPOSE_FADE_OUT=1.0
COMPOSE_MUSIC_REF_LUFS=-14
COMPOSE_DUCKING=false
