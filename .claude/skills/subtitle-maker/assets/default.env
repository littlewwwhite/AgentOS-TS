# Subtitle Maker 默认配置

# aos-cli audio.transcribe 参数（ASR 精确度优先）
ASR_MODEL=gemini-3.1-pro-preview
ASR_TEMPERATURE=0.3
ASR_THINKING_LEVEL=low
ASR_MEDIA_RESOLUTION=medium

# ASR 视频压缩参数（侧重语音质量）
COMPRESS_BEFORE_UPLOAD=true
ASR_COMPRESS_RESOLUTION=480
ASR_COMPRESS_FPS=6
ASR_COMPRESS_CRF=32
ASR_AUDIO_BITRATE=128k
COMPRESS_SKIP_UNDER_MB=100

# 字幕烧录编码参数（样式参数已迁移至 assets/styles.json）
BURN_CRF=18

# 字幕样式预设（auto=自动根据视频方向选择，或指定预设名如 vertical/horizontal_clean）
SUBTITLE_STYLE=auto
