# ═══════════════ aos-cli video.analyze ═══════════════
# aos-cli video.analyze 模型 ID（如 gemini-3.1-pro-preview, gemini-3-flash-preview）
VIDEO_ANALYZE_MODEL=gemini-3.1-pro-preview
# 生成温度
VIDEO_ANALYZE_TEMPERATURE=1.0
# 推理深度：minimal / low / medium / high（越高越慢越精确）
VIDEO_ANALYZE_THINKING_LEVEL=low
# 视频采样分辨率：low / medium / high / ultra_high（影响 token 消耗）
VIDEO_ANALYZE_MEDIA_RESOLUTION=medium

# ═══════════════ 视频压缩（上传前） ═══════════════
# 是否在调用 aos-cli video.analyze 前压缩视频
COMPRESS_BEFORE_UPLOAD=true
# 压缩目标分辨率（像素高度）
COMPRESS_RESOLUTION=720
# 压缩目标帧率
COMPRESS_FPS=12
# 编码质量（18=高质量大文件，28=低质量小文件）
COMPRESS_CRF=28
# 文件小于此 MB 值时跳过压缩
COMPRESS_SKIP_UNDER_MB=100

# ═══════════════ PySceneDetect 切镜检测 ═══════════════
# 检测模式：adaptive（动态阈值，推荐）/ content（固定阈值）
SCENE_DETECT_MODE=adaptive
# content 模式的固定阈值
SCENE_DETECT_THRESHOLD=37.0
# adaptive 模式的偏离倍率（越小越灵敏）
SCENE_DETECT_ADAPTIVE_THRESHOLD=3.0
# adaptive 模式的最小变化量门槛（过滤静止画面噪声）
SCENE_DETECT_MIN_CONTENT_VAL=15.0
# adaptive 模式的滑动窗口半径（帧数）
SCENE_DETECT_WINDOW_WIDTH=2
# 最小镜头时长（秒），短于此值的片段会被忽略
SCENE_DETECT_MIN_SCENE_SEC=1.0

# ═══════════════ 变体处理 ═══════════════
# 每个 clip 最多处理的变体数量（超出截断，取前 N 个）
MAX_VARIANTS=6

# ═══════════════ Phase 1 并行 ═══════════════
# clip 级并行数（同时处理多少个 clip，每个 clip 会占用模型配额）
PHASE1_CLIP_CONCURRENCY=3
# 单 clip 内变体级并行数（切镜检测 + 上传同时处理多少个变体）
PHASE1_VARIANT_CONCURRENCY=3

# ═══════════════ 输出 ═══════════════
# 输出目录（相对于 CWD，CLI -o 可覆盖）
OUTPUT_DIR=output

# ═══════════════ 第二阶段：循环剪辑引擎 ═══════════════
# 循环评估分数阈值（达到即终止循环）
LOOP_SCORE_THRESHOLD=7.5
# 最大循环轮次
LOOP_MAX_ITERATIONS=3
# scn 级并行数
CONCURRENCY=4
# 循环评估使用的 aos-cli video.analyze 模型
LOOP_VIDEO_ANALYZE_MODEL=gemini-3.1-pro-preview
# 循环评估推理深度
LOOP_VIDEO_ANALYZE_THINKING_LEVEL=low
# 循环评估生成温度
LOOP_VIDEO_ANALYZE_TEMPERATURE=1.0
# 循环评估视频采样分辨率
LOOP_VIDEO_ANALYZE_MEDIA_RESOLUTION=medium
